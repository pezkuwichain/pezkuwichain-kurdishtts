# ── KurdîTV environment ───────────────────────────────────────────
# Copy to `.env` for local development. NEVER commit a real .env.
# In production these are provided by the systemd drop-in
# (/etc/systemd/system/kurdishtts.service.d/env.conf) and never live in git.

# ── Gemini / Veo (Create Videos feature) ──────────────────────────
# Generative Language API key with Veo access. Required for /create.
GEMINI_API_KEY=your-gemini-api-key-here
# Veo image-to-video model id.
GEMINI_VIDEO_MODEL=veo-3.0-generate-001

# ── Dubbing pipeline ──────────────────────────────────────────────
# Whisper model size: tiny | base | small | medium | large-v3
DUB_WHISPER_MODEL=small
# Max input duration (seconds) and size (bytes).
DUB_MAX_SECONDS=180
DUB_MAX_BYTES=125829120

# ── Hugging Face model cache ──────────────────────────────────────
HF_HOME=/root/.cache/huggingface
